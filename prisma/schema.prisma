// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id                   String         @id @default(cuid())
  clientName           String
  clientEmail          String
  clientPhone          String
  clientCountry        String?
  clientState          String?
  clientCity           String?
  clientZipCode        String?
  clientStreetAddress  String?
  clientAddress        String?
  currency             String         @default("USD")
  totalAmount          Float
  paymentMethod        String
  status               String         @default("pending") // pending, confirmed, declined
  paymentConfirmedCode String?
  adminNote            String?        // Note added by admin when confirming or declining
  masseuseGender       String?
  masseuseBodyBuild    String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  paymentProofs        PaymentProof[]
}

model PaymentProof {
  id              String   @id @default(cuid())
  orderId         String
  cardImageUrl    String?
  receiptImageUrl String?
  uploadedAt      DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id])
}

model Lead {
  id        String   @id @default(cuid())
  name      String?
  email     String
  ip        String?
  city      String?
  region    String?
  country   String?
  source    String?  @default("popup") // popup, checkout, etc.
  createdAt DateTime @default(now())
}
